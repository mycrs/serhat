{
  "name": "serhat-m3u-admin",
  "version": "1.0.0",
  "description": "Admin panel for M3U playlist management",
  "scripts": {
    "start": "concurrently \"npm run backend:start\" \"npm run frontend:start\"",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "cd backend && npm run dev",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:start": "cd backend && npm start",
    "frontend:start": "cd frontend && npm start",
    "backend:install": "cd backend && npm install",
    "frontend:install": "cd frontend && npm install",
    "install-all": "npm run backend:install && npm run frontend:install",
    "build": "npm run frontend:build",
    "frontend:build": "cd frontend && npm run build",
    "health": "curl -f http://localhost:5000/health && curl -f http://localhost:3000/api/healthz || echo 'Services not running'"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}